APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Set to `git rev-parse HEAD` for immutable evaluation provenance in containers.
GIT_COMMIT=
# Docker build option; ignored by the application Settings model.
INSTALL_LOCAL_MODELS=true
API_KEY=
ADMIN_API_KEY=
CORS_ORIGINS=["http://localhost:3000"]

POSTGRES_PASSWORD=rag
POSTGRES_PORT=5432
# For Compose's bundled database, keep this password (URL-encoded when needed)
# in sync with POSTGRES_PASSWORD. It may also point to a managed PostgreSQL.
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

GITHUB_TOKEN=
GITHUB_REPOSITORY=kubernetes/kubernetes
GITHUB_BRANCH=master

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_API_VERSION=
LLM_DEPLOYMENT=
LLM_TOKENIZER_PROVIDER=auto
# Required when an LLM is configured; select a tokenizer matching the served model.
LLM_TOKENIZER_MODEL=
LLM_TOKENIZER_ALLOW_REGEX_FALLBACK=false

JUDGE_PROVIDER=
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=
JUDGE_API_VERSION=
JUDGE_DEPLOYMENT=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_CONCURRENCY=8
# auto: OpenAI-compatible uses model catalog; Azure probes its deployment with 1 token.
LLM_HEALTHCHECK_MODE=auto
ANSWER_MAX_TOKENS=1200
QUERY_REWRITE_MAX_TOKENS=256
QUERY_REWRITE_HISTORY_TURNS=4
JUDGE_MAX_TOKENS=256
JUDGE_TIMEOUT_SECONDS=20

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_API_VERSION=
EMBEDDING_DEPLOYMENT=
EMBEDDING_DIMENSION=1024
# Must match the physical vector(N) column provisioned by Alembic.
DATABASE_VECTOR_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_CONCURRENCY=2
# auto: OpenAI-compatible uses model catalog; Azure embeds one probe token.
EMBEDDING_HEALTHCHECK_MODE=auto

RERANKER_PROVIDER=local
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_BATCH_SIZE=16
RERANKER_TIMEOUT_SECONDS=60
RERANKER_MAX_CONCURRENCY=2
# auto/inference calls POST /rerank with one document; endpoint uses the relative path below.
RERANKER_HEALTHCHECK_MODE=auto
RERANKER_HEALTHCHECK_RESOURCE=
RERANKER_SCORE_THRESHOLD=
PROVIDER_MAX_RETRIES=3

KEYWORD_TOP_K=30
VECTOR_TOP_K=30
RERANK_TOP_K=8
RRF_K=60
RETRIEVAL_MODE=hybrid
FUSION_MODE=rrf
KEYWORD_FUSION_WEIGHT=0.5
VECTOR_FUSION_WEIGHT=0.5

CHUNK_TARGET_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=80
CHUNK_MIN_TOKENS=80
CHUNK_TOKENIZER_PROVIDER=auto
# Required for remote embedding providers; local mode reuses EMBEDDING_MODEL.
CHUNK_TOKENIZER_MODEL=
# Explicit emergency fallback only; regex counts are not model-accurate.
CHUNK_TOKENIZER_ALLOW_REGEX_FALLBACK=false

NO_ANSWER_TOP1_THRESHOLD=
NO_ANSWER_AVG_THRESHOLD=
NO_ANSWER_MARGIN_THRESHOLD=
NO_ANSWER_TOP_K=3
NO_ANSWER_TOPIC_OVERLAP_THRESHOLD=0.05
NO_ANSWER_GRAY_ZONE_LOWER=0.35
NO_ANSWER_GRAY_ZONE_UPPER=0.65
EVIDENCE_SUFFICIENCY_THRESHOLD=0.60
CITATION_COVERAGE_THRESHOLD=0.60
MAX_CONTEXT_TOKENS=6000

ENABLE_QUERY_REWRITE=true
ENABLE_RERANKER=true
ENABLE_CITATION_VALIDATION=true
ENABLE_TELEMETRY=false
OTEL_SERVICE_NAME=opensource-doc-intelligence
OTEL_EXPORTER_OTLP_ENDPOINT=

PRICING_CONFIG_PATH=config/pricing.yaml
PROMPT_DIRECTORY=prompts
INGESTION_WORKER_POLL_SECONDS=2
EVALUATION_WORKER_POLL_SECONDS=2
# PostgreSQL-backed admission limits and global worker concurrency caps.
INGESTION_MAX_OUTSTANDING_JOBS=100
EVALUATION_MAX_OUTSTANDING_RUNS=10
INGESTION_MAX_CONCURRENT_JOBS=1
EVALUATION_MAX_CONCURRENT_RUNS=1
QUEUE_RETRY_AFTER_SECONDS=5
EVALUATION_CONCURRENCY=1
EVALUATION_HEARTBEAT_SECONDS=30
EVALUATION_STALE_SECONDS=86400
MAX_QUERY_LENGTH=4000
